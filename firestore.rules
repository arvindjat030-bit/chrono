rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (required, 'admin' | 'customer')
    //   - createdAt: timestamp (required)
    //   - wishlist: list (product IDs)
    //   - cart: list (objects with productId and quantity)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - brand: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   ... other specs
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "arvchoudhary317@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'brand', 'price', 'category']) &&
             data.name is string && data.name.size() < 200 &&
             data.brand is string &&
             data.price is number && data.price > 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status']) &&
             data.userId is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'customer' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
