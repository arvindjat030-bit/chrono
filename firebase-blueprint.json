{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "cart": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Luxury watch details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "INR"] },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "specifications": {
          "type": "object",
          "properties": {
            "caseSize": { "type": "string" },
            "movement": { "type": "string" },
            "powerReserve": { "type": "string" },
            "waterResistance": { "type": "string" },
            "material": { "type": "string" },
            "strap": { "type": "string" }
          }
        },
        "stock": { "type": "integer" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection of user profiles" },
    "products": { "schema": "Product", "description": "Collection of luxury watches" },
    "orders": { "schema": "Order", "description": "Collection of customer orders" }
  }
}
